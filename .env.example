APP_NAME="المصمم الذكي للديكور"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://smartdecorat.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=smartdecorat_db
DB_USERNAME=smartdecorat_user
DB_PASSWORD=your_password_here

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_DOMAIN=.smartdecorat.com
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

LOG_CHANNEL=stack
LOG_LEVEL=warning

MAIL_MAILER=log
